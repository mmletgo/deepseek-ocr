# ============================================
# DeepSeek-OCR 配置文件
# 复制此文件为 .env 并修改对应值
# ============================================

# --- vLLM 推理引擎配置 ---
# VLLM_MODEL_PATH=deepseek-ai/DeepSeek-OCR-2    # HuggingFace repo ID 或本地路径
# VLLM_GPU_MEMORY_UTILIZATION=0.85
# VLLM_MAX_MODEL_LEN=8192
# VLLM_DTYPE=bfloat16
# VLLM_TENSOR_PARALLEL_SIZE=1
# VLLM_MAX_RETRIES=3
# VLLM_RETRY_DELAY=2.0
# VLLM_MAX_CONCURRENCY=100

# --- PDF 渲染配置 ---
# PDF_DPI=200
# PDF_MAX_DIMENSION=1920
# PDF_IMAGE_FORMAT=png
# PDF_OUTPUT_MODE=dual_layer    # dual_layer 或 rewrite

# --- Web 服务配置 ---
# WEB_HOST=0.0.0.0
# WEB_PORT=8080
# WEB_UPLOAD_DIR=./uploads
# WEB_MAX_UPLOAD_SIZE_MB=200

# --- LLM 翻译配置 (OpenAI 兼容接口) ---
# TRANSLATION_BASE_URL=https://api.openai.com/v1
# TRANSLATION_API_KEY=
# TRANSLATION_MODEL=gpt-4o-mini
# TRANSLATION_TIMEOUT=120
# TRANSLATION_MAX_RETRIES=3
# TRANSLATION_TEMPERATURE=0.3

# --- 输出配置 ---
# OUTPUT_DIR=./output
